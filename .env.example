# Copy this file to `.env.e2e.local` for local provider-backed e2e tests.
# This file is safe to commit; `.env.e2e.local` is gitignored.

# Explicit opt-in for real provider calls.
IMAGEN_E2E=0

# Optional prompt override used by e2e tests.
IMAGEN_E2E_PROMPT=A small watercolor fox sitting on a mossy rock

# Optional output directory for generated files.
IMAGEN_E2E_OUTPUT_DIR=.tmp/imagen-e2e

# Chat completions target
IMAGEN_E2E_CHAT_BASE_URL=
IMAGEN_E2E_CHAT_API_KEY=
IMAGEN_E2E_CHAT_MODEL=gpt-4o
IMAGEN_E2E_CHAT_PROVIDER_ID=e2e-chat

# Images endpoint target
IMAGEN_E2E_IMAGES_BASE_URL=
IMAGEN_E2E_IMAGES_API_KEY=
IMAGEN_E2E_IMAGES_MODEL=dall-e-3
IMAGEN_E2E_IMAGES_PROVIDER_ID=e2e-images
